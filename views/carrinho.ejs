<%- include('partials/header') %>

<h2>Meu Carrinho</h2>

<% if (carrinho.length === 0) { %>
  <p>Seu carrinho está vazio. <a href="/produtos">Ver produtos</a></p>
<% } else { %>

<div class="row">
  <!-- Coluna ESQUERDA: itens do carrinho -->
  <div class="col-md-5">
    <h4>Produtos</h4>
    <table class="table table-sm">
      <thead>
        <tr><th>Produto</th><th>Preço</th><th>Qtd</th><th>Subtotal</th><th></th></tr>
      </thead>
      <tbody>
        <% carrinho.forEach(item => { %>
          <tr>
            <td><%= item.nome %></td>
            <td>R$ <%= item.preco.toFixed(2) %></td>
            <td>
              <form method="POST" action="/carrinho/atualizar" class="d-inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="id" value="<%= item.produtoId %>">
                <input type="number" name="quantidade" value="<%= item.quantidade %>" min="1" style="width:60px" onchange="this.form.submit()">
              </form>
            </td>
            <td>R$ <%= (item.preco * item.quantidade).toFixed(2) %></td>
            <td>
              <form method="POST" action="/carrinho/remover/<%= item.produtoId %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-danger btn-sm">Remover</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="3">Total</th>
          <th>R$ <%= carrinho.reduce((t,i)=>t+i.preco*i.quantidade,0).toFixed(2) %></th>
          <th></th>
        </tr>
      </tfoot>
    </table>
  </div>

  <!-- Coluna DIREITA: formulário de entrega/pagamento -->
  <div class="col-md-7">
    <h4>Dados para Entrega</h4>

    <% if (typeof erros !== 'undefined' && erros.length > 0) { %>
      <div class="alert alert-danger">
        <% erros.forEach(e => { %><p><%= e.msg %></p><% }); %>
      </div>
    <% } %>

    <form method="POST" action="/pedidos/checkout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="row">
        <div class="col-md-8 mb-3">
          <label>Nome completo *</label>
          <input type="text" name="nome" class="form-control" value="<%= dados.nome || '' %>" required>
        </div>
        <div class="col-md-4 mb-3">
          <label>Telefone *</label>
          <input type="tel" name="telefone" class="form-control" value="<%= dados.telefone || '' %>" placeholder="(11) 99999-9999" required>
        </div>
      </div>

      <div class="mb-3">
        <label>CEP *</label>
        <input type="text" name="cep" class="form-control" value="<%= dados.cep || '' %>" placeholder="00000-000" required>
      </div>

      <div class="row">
        <div class="col-md-8 mb-3">
          <label>Logradouro *</label>
          <input type="text" name="logradouro" class="form-control" value="<%= dados.logradouro || '' %>" placeholder="Rua, Avenida..." required>
        </div>
        <div class="col-md-4 mb-3">
          <label>Número *</label>
          <input type="text" name="numero" class="form-control" value="<%= dados.numero || '' %>" required>
        </div>
      </div>

      <div class="mb-3">
        <label>Complemento</label>
        <input type="text" name="complemento" class="form-control" value="<%= dados.complemento || '' %>" placeholder="Apto, Bloco, etc.">
      </div>

      <div class="row">
        <div class="col-md-5 mb-3">
          <label>Bairro *</label>
          <input type="text" name="bairro" class="form-control" value="<%= dados.bairro || '' %>" required>
        </div>
        <div class="col-md-5 mb-3">
          <label>Cidade *</label>
          <input type="text" name="cidade" class="form-control" value="<%= dados.cidade || '' %>" required>
        </div>
        <div class="col-md-2 mb-3">
          <label>UF *</label>
          <input type="text" name="estado" class="form-control" value="<%= dados.estado || '' %>" maxlength="2" placeholder="SP" required>
        </div>
      </div>

      <hr>
      <h5>Forma de Pagamento</h5>
      <div class="mb-3">
        <div class="form-check">
          <input class="form-check-input" type="radio" name="pagamento" value="pix" id="pix" checked>
          <label class="form-check-label" for="pix">PIX</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="pagamento" value="cartao" id="cartao">
          <label class="form-check-label" for="cartao">Cartão (na entrega)</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="pagamento" value="dinheiro" id="dinheiro">
          <label class="form-check-label" for="dinheiro">Dinheiro (na entrega)</label>
        </div>
      </div>

      <button type="submit" class="btn btn-success btn-lg w-100">✅ Finalizar Pedido</button>
    </form>
  </div>
</div>

<% } %>

<%- include('partials/footer') %>