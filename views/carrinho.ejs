
<%- include('partials/header') %>
<h2>Carrinho de compras</h2>
<% if (carrinho.length === 0) { %>
  <p>Seu carrinho esta vazio. <a href="/produtos">Ver produtos</a></p>
<% } else { %>
  <table class="table">
    <thead><tr><th>Produto</th><th>Preco</th><th>Quantidade</th><th>Subtotal</th><th></th></tr></thead>
    <tbody>
      <% carrinho.forEach(item => { %>
        <tr>
          <td><%= item.nome %></td>
          <td>R$ <%= item.preco.toFixed(2) %></td>
          <td>
            <form method="POST" action="/carrinho/atualizar" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="id" value="<%= item.produtoId %>">
              <input type="number" name="quantidade" value="<%= item.quantidade %>" min="1" style="width:60px" onchange="this.form.submit()">
            </form>
          </td>
          <td>R$ <%= (item.preco * item.quantidade).toFixed(2) %></td>
          <td>
            <form method="POST" action="/carrinho/remover/<%= item.produtoId %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-danger btn-sm">Remover</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
    <tfoot>
      <tr><th colspan="3">Total</th><th>R$ <%= carrinho.reduce((t,i)=>t+i.preco*i.quantidade,0).toFixed(2) %></th><th></th></tr>
    </tfoot>
  </table>
  <% if (usuario) { %>
    <form method="POST" action="/pedidos/checkout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-success">Finalizar compra</button>
    </form>
  <% } else { %>
    <a href="/auth/login" class="btn btn-warning">Faca login para finalizar</a>
  <% } %>
<% } %>
<%- include('partials/footer') %>
