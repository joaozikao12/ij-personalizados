
<%- include('../partials/header') %>
<h2>Produtos cadastrados</h2>
<a href="/admin/produtos/novo" class="btn btn-success mb-3">Novo produto</a>
<table class="table">
  <thead><tr><th>ID</th><th>Nome</th><th>Preco</th><th>Estoque</th></tr></thead>
  <tbody>
    <% produtos.forEach(produto => { %>
      <tr><td><%= produto.id %></td><td><%= produto.nome %></td><td>R$ <%= parseFloat(produto.preco).toFixed(2) %></td><td><%= produto.estoque %></td></tr>
    <% }); %>
  </tbody>
</table>
<%- include('../partials/footer') %>
