
<%- include('../partials/header') %>
<div class="row">
  <div class="col-md-6">
    <img src="<%= produto.imagem || 'https://via.placeholder.com/500x500?text=Caneca' %>" class="img-fluid" alt="<%= produto.nome %>">
  </div>
  <div class="col-md-6">
    <h2><%= produto.nome %></h2>
    <p><%= produto.descricao %></p>
    <h3>R$ <%= parseFloat(produto.preco).toFixed(2) %></h3>
    <p>Estoque: <%= produto.estoque %></p>
    <form method="POST" action="/carrinho/adicionar/<%= produto.id %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-success btn-lg" <%= produto.estoque < 1 ? 'disabled' : '' %>>Adicionar ao carrinho</button>
    </form>
    <a href="/produtos" class="btn btn-secondary mt-3">Voltar</a>
  </div>
</div>
<%- include('../partials/footer') %>
